<script>
  const spToggle  = document.getElementById('sp-menu-toggle')!;
  const spClose   = document.getElementById('sp-menu-close')!;
  const spOverlay = document.getElementById('sp-menu-overlay')!;
  const spMenu    = document.getElementById('sp-mobile-menu')!;

  function spOpen() {
    spMenu.setAttribute('aria-hidden', 'false');
    spMenu.classList.add('is-open');
    spToggle.setAttribute('aria-expanded', 'true');
    document.body.style.overflow = 'hidden';
  }

  function spCloseMenu() {
    spMenu.setAttribute('aria-hidden', 'true');
    spMenu.classList.remove('is-open');
    spToggle.setAttribute('aria-expanded', 'false');
    document.body.style.overflow = '';
  }

  spToggle.addEventListener('click', spOpen);
  spClose.addEventListener('click', spCloseMenu);
  spOverlay.addEventListener('click', spCloseMenu);

  spMenu.querySelectorAll('.mobile-menu__link, .mobile-menu__wa, .mobile-menu__cta').forEach(el => {
    el.addEventListener('click', spCloseMenu);
  });
</script>

<!-- Breadcrumb + page hero -->
<section class="page-hero">
  <div class="container">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <ol class="breadcrumb__list">
        <li><a href="/">Home</a></li>
        <li aria-current="page">{page.title}</li>
      </ol>
    </nav>
    <div class="page-hero__content">
      <span class="page-hero__badge">
        {page.tier === 1 ? 'Core Service' : 'Expert Guide'}
      </span>
      <h1 class="page-hero__h1">{page.h1}</h1>
      {page.headerImage && (
        <div class="page-hero__header-image">
          <img
            src={page.headerImage.src}
            alt={page.headerImage.alt}
            title={page.headerImage.title}
            width={page.headerImage.width}
            height={page.headerImage.height}
            loading="eager"
            decoding="async"
            fetchpriority="high"
          />
        </div>
      )}
      <p class="page-hero__intro">{page.intro}</p>
      <a href={header.ctaButton.href} class="page-hero__cta">{header.ctaButton.label} →</a>
    </div>
  </div>
</section>

<!-- Main content -->
<main class="page-content">
  <div class="container page-content__grid">

    <!-- Article -->
    <article class="page-article">
      {rawHtml ? (
        <Fragment set:html={rawHtml} />
      ) : (
        <>
          {page.h2Sections.map((section) => (
            <section class="page-article__section">
              <h2 class="page-article__h2">{section.heading}</h2>
              {section.body
                ? <p class="page-article__body">{section.body}</p>
                : (
                  <p class="page-article__body page-article__body--placeholder">
                    Our specialists provide expert, examiner-aware guidance on {section.heading.toLowerCase()}.
                    Contact us to discuss your specific requirements and get tailored support.
                  </p>
                )
              }
            </section>
          ))}
          {page.h2Sections.length > 2 && (
            <div class="inline-cta">
              <p class="inline-cta__text">Need expert help with this topic?</p>
              <a href={header.ctaButton.href} class="inline-cta__btn">{header.ctaButton.label}</a>
            </div>
          )}
        </>
      )}
    </article>

    <!-- Sidebar -->
    <aside class="page-sidebar">
      <!-- Order box -->
      <div class="sidebar-card sidebar-card--cta">
        <h3 class="sidebar-card__heading">Get Expert Help</h3>
        <p class="sidebar-card__text">
          Specialist {header.logoText} writers, on-time delivery, plagiarism-free guarantee.
        </p>
        <a href={header.ctaButton.href} class="sidebar-card__btn">
          {header.ctaButton.label}
        </a>
        <ul class="sidebar-card__trust">
          <li>✓ Plagiarism-free</li>
          <li>✓ On-time delivery</li>
          <li>✓ Free revisions</li>
          <li>✓ Expert writers</li>
        </ul>
      </div>

      <!-- Related pages -->
      {page.relatedPages.length > 0 && (
        <div class="sidebar-card">
          <h3 class="sidebar-card__heading">Related Topics</h3>
          <ul class="sidebar-card__links">
            {page.relatedPages.map((rp) => (
              <li>
                <a href={`/${rp.slug}`} class="sidebar-card__link">
                  {rp.title} →
                </a>
              </li>
            ))}
          </ul>
        </div>
      )}
    </aside>
  </div>

  <!-- FAQ strip -->
  {faqItems.length > 0 && (
    <section class="page-faq">
      <div class="container">
        <h2 class="section-heading">Common Questions</h2>
        <div class="page-faq__list">
          {faqItems.map((item) => (
            <details class="faq__item">
              <summary class="faq__question">
                <span class="faq__question-text">{item.question}</span>
                <span class="faq__icon" aria-hidden="true"></span>
              </summary>
              <div class="faq__answer">
                <div class="faq__answer-inner">
                  <p>{item.answer}</p>
                </div>
              </div>
            </details>
          ))}
        </div>
      </div>
    </section>
  )}
</main>

