---
/**
 * ServicePage.astro
 * Renders an inner service/qualification page from a content.json page entry.
 * Used by src/pages/[...slug].astro
 */

interface H2Section {
  heading: string;
  body: string;
}

interface RelatedPage {
  title: string;
  slug: string;
}

interface HeaderImage {
  src: string;
  alt: string;
  title: string;
  width: number;
  height: number;
}

interface PageData {
  slug: string;
  tier: number;
  title: string;
  metaTitle: string;
  metaDescription: string;
  h1: string;
  intro: string;
  h2Sections: H2Section[];
  relatedPages: RelatedPage[];
  contextualQuestion: string;
  headerImage?: HeaderImage;
}

interface SiteConfig {
  header: {
    logoText: string;
    logoHref: string;
    navLinks: { label: string; href: string }[];
    ctaButton: { label: string; href: string };
  };
  finalCta: {
    heading: string;
    subtext: string;
    button: { label: string; href: string };
  };
  footer: {
    logoText: string;
    description: string;
    columns: { heading: string; links: { label: string; href: string }[] }[];
    copyright: string;
  };
  faq?: {
    heading: string;
    items: { question: string; answer: string }[];
  };
}

interface Props {
  page: PageData;
  config: SiteConfig;
  rawHtml?: string;
}

const { page, config, rawHtml = '' } = Astro.props;
const { header, finalCta, footer, faq } = config;

// Show first 4 FAQ items on inner pages
const faqItems = faq?.items?.slice(0, 4) ?? [];
